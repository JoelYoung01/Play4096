{
	"name": "play4096",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "eslint . --fix",
		"init-db": "node src/lib/init-db.js",
		"db:push": "drizzle-kit push --config drizzle.config.js",
		"db:generate": "drizzle-kit generate --config drizzle.config.js",
		"db:migrate": "drizzle-kit migrate --config drizzle.config.js",
		"db:studio": "drizzle-kit studio --config drizzle.config.js",
		"db:studio-deployed": "drizzle-kit studio --config drizzle.config.js --host 0.0.0.0 --port 3001",
		"db:seed": "node src/scripts/seed.js"
	},
	"devDependencies": {
		"@eslint/compat": "latest",
		"@eslint/js": "latest",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.24.0",
		"@sveltejs/adapter-node": "^5.3.1",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^9.34.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"mode-watcher": "^1.1.0",
		"pino-pretty": "^13.1.1",
		"playwright": "^1.61.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.0.0",
		"vite": "^7.0.4",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"better-sqlite3",
			"esbuild",
			"sqlite3"
		],
		"strictDepBuilds": true
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"better-sqlite3": "^11.8.0",
		"drizzle-kit": "^0.30.2",
		"drizzle-orm": "^0.40.0",
		"nodemailer": "^7.0.6",
		"pino": "^9.11.0",
		"sqlite3": "^5.1.7",
		"stripe": "^18.5.0"
	},
	"packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8"
}
